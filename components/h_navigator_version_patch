# H Navigator version correction patch, for Brave > Brave Origin

REAL="/opt/hlinux/brave-nightly/brave-browser-nightly"   # the true binary

# Intercept version argument
for arg in "$@"; do
    case "$arg" in
        --version|-version)
            raw="$("$REAL" --version 2>/dev/null)"
            # Extract only the version number (e.g. 1.2.3.4)
            ver="$(printf '%s\n' "$raw" | grep -oE '[0-9]+([.][0-9]+){2,3}')"
            echo "Brave Origin $ver nightly"
            exit 0
            ;;
    esac
done

exec "$REAL" "$@"
