#h navigator script for blackbox-hwm, Script version 13.1

#CHANGELOG NOTABLES
#
#Version 4.1.0 marked the introduction of h-swap dir in /tmp
#Version 4.0.0 marked a transition from pre-built packages to H-Linux compiled packages, as h-navigator
#Version 3.11.0 marked a transition from Brave base > Origin base. Nightly channel remains unchanged

# Create the h-swap dir
mkdir -p /tmp/h-swap

echo
echo "Loading h navigator"
echo

#to display logo with 1:1 proportions
viu --height 14 --width 26 ~/Pictures/h-navigator-logo.png

echo
#toilet --filter metal:border "H Navigator"
tput setaf 1; figlet -f banner "H Navigator"; tput sgr0
echo "With AI, Search Bridge and SEXTANT."
echo
~/.hwm/scripts/h_navigator_version_patch --version
echo "Version 4.2.0-1, built on Brave Origin (nightly). 🔥 [Patched with Singleton Jailbreak]"
echo
echo "Loaded."
echo "running"
echo

mkdir -p /tmp/h-swap
cp -f $HOME/Pictures/w3c.png /tmp/h-swap
zenity --notification --text="H Navigator\nWith AI, Search Bridge and SEXTANT." --timeout=5 --icon='/tmp/h-swap/w3c.png' &>/dev/null

#beta
openssl rand -base64 48 > /tmp/1V/sys/ctrl/strgctrl0/strgpri0/vfunit0-drive_C/h_navigator_auth_tmp_a
openssl rand -base64 48 > /tmp/1V/sys/ctrl/strgctrl0/strgpri0/vfunit0-drive_C/h_navigator_auth_tmp_b
openssl rand -base64 48 > /tmp/1V/sys/ctrl/strgctrl0/strgpri0/vfunit0-drive_C/h_navigator_auth_tmp_c
openssl rand -base64 48 > /tmp/1V/sys/ctrl/strgctrl0/strgpri0/vfunit0-drive_C/h_navigator_auth_tmp_d


# And now the opening Jailbreak
PROFILE_DIR="$HOME/.config/BraveSoftware/Brave-Browser"

# Only remove stale locks if no Brave process exists
if ! pgrep -f brave-browser-nightly >/dev/null; then
  rm -fr "$PROFILE_DIR"/Singleton*
fi

h-navigator --user-data-dir="$HOME/.config/BraveSoftware/Brave-Browser" --proxy-server="192.168.1.69:800" &>/dev/null &
LAUNCHER_PID=$!

# Wait loop
for _ in $(seq 1 100); do
  xdotool search --class "Brave-browser-nightly" >/dev/null 2>&1 && break
  sleep 0.2
done

# Fail fast if no Brave window appears (and shred temp auth)
if ! xdotool search --class "Brave-browser-nightly" >/dev/null 2>&1; then
  echo "H Navigator launch failed: no Brave window detected."
  shred -u /tmp/1V/sys/ctrl/strgctrl0/strgpri0/vfunit0-drive_C/h_navigator_auth_tmp* 2>/dev/null || true
  exit 1
fi

# Wait for Brave to fully fork its master process
sleep 2

# Find the real Brave master — the binary with no --type= flag
BRAVE_PID=$(pgrep -f "/opt/hlinux/brave-nightly/brave" | while read -r pid; do
  cmdline=$(tr '\0' ' ' < /proc/$pid/cmdline 2>/dev/null)
  if [[ "$cmdline" != *"--type="* ]]; then
    echo "$pid"
    break
  fi
done)

# Fallback: lowest PID of the real binary (not the bash wrapper)
if [[ -z "$BRAVE_PID" ]]; then
  BRAVE_PID=$(pgrep -f "/opt/hlinux/brave-nightly/brave" | sort -n | head -1)
fi

echo "Monitoring H Navigator PID: $BRAVE_PID"

# Launch Sextant core monitor in a new terminal window
SEXTANT_PATH="$(realpath "$(dirname "$0")/sextant.sh")"
if [[ -x "$SEXTANT_PATH" ]]; then
  if command -v cherry-terminal &>/dev/null; then
    cherry-terminal --title "⚓ SEXTANT — Core monitor for H Navigator | Blackbox-hwm" -e bash "$SEXTANT_PATH" --monitor "$BRAVE_PID" 1 "H Navigator" &>/dev/null &
  elif command -v xterm &>/dev/null; then
    xterm -e bash "$SEXTANT_PATH" --monitor "$BRAVE_PID" 1 "H Navigator" &>/dev/null &
  elif command -v gnome-terminal &>/dev/null; then
    gnome-terminal -- bash "$SEXTANT_PATH" --monitor "$BRAVE_PID" 1 "H Navigator" &>/dev/null &
  else
    echo "SEXTANT: no supported terminal found (cherry-terminal, xterm, gnome-terminal) — skipping monitor."
  fi
else
  echo "SEXTANT: sextant.sh not found or not executable at $SEXTANT_PATH — skipping monitor."
fi

# Keep enforcing the title using the PID we already found
( while [ -n "$BRAVE_PID" ] && ps -p "$BRAVE_PID" > /dev/null; do
    # Search for all windows belonging to the master Brave PID
    WIDS=$(xdotool search --pid "$BRAVE_PID" 2>/dev/null)
    for WID in $WIDS; do
      xdotool set_window --name "H Navigator. Version 4.2.0-1, built on Brave Origin (nightly). [Patched with Singleton Jailbreak]" "$WID"
    done
    sleep 2
  done ) &

# Above works and can still be used if this fails
#while xdotool getwindowname "$WINDOW_ID" >/dev/null 2>&1; do
#    xdotool set_window --name "H Navigator. Version 4.2.0-1, built on Brave Origin (nightly). [Patched with Singleton Jailbreak]"
#    sleep 2
#done

echo

echo "🔒 Unique session keys generated by OpenSSL."
echo "H Navigator is running."

# Verbose output can follow, likely limited
echo ""
echo "------------------------------------------------------------"
echo "                  Warnings and Errors Log!                  "
echo "Note: Warnings are not errors and can be safely ignored.    "
echo "------------------------------------------------------------"
echo ""

# Wait for the main Brave launcher process to exit
wait "$LAUNCHER_PID" 2>/dev/null || true

# Extra safety: wait for any remaining Brave processes
while pgrep -f brave >/dev/null; do
  sleep 0.5
done

# And now the closing Jailbreak
rm -fr "$PROFILE_DIR"/Singleton*

sleep 2

# Clean up h-swap dir
rm -fr /tmp/h-swap

echo
echo -n "Press Return to exit session securely... "
read -r _

# Secure exit (success path)
shred -u /tmp/1V/sys/ctrl/strgctrl0/strgpri0/vfunit0-drive_C/h_navigator_auth_tmp* 2>/dev/null || true

echo "Exiting now."
echo
exit 0
